    "drizzle-orm": "^0.45.1",
    "fastify": "^5.2.1",
    "jsdom": "^26.0.0",
    "postgres": "^3.4.8",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.21",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.10",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.7.1",
    "vitest": "^2.1.8"
  }
